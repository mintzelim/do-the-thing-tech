{
  "buildCommand": "npm run build",
  "installCommand": "npm install --include=optional",
  "framework": "express",
  "functions": {
    "dist/index.js": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "redirects": [
    {
      "source": "/:path((?!api).*)*",
      "has": [
        {
          "type": "host",
          "value": "www.dothething.tech"
        }
      ],
      "destination": "https://dothething.tech/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "do-the-thing-tech.vercel.app"
        }
      ],
      "destination": "https://dothething.tech/:path*",
      "permanent": true
    }
  ]
}